generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── USUARIOS ───

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  hashedPassword  String?
  image           String?
  role            UserRole  @default(BUYER)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  artisan         Artisan?
  orders          Order[]
  reviews         Review[]
  questions       ProductQuestion[]
  favorites       Favorite[]
  cartItems       CartItem[]
  disputes        Dispute[]

  @@map("users")
}

enum UserRole {
  BUYER
  ARTISAN
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─── ORFEBRES ───

model Artisan {
  id                String        @id @default(cuid())
  userId            String        @unique
  slug              String        @unique
  displayName       String
  bio               String        @db.Text
  story             String?       @db.Text
  location          String
  specialty         String
  materials         String[]
  profileImage      String?
  workshopImages    String[]
  videoUrl          String?
  socialLinks       Json?
  rut               String?
  phone             String?

  mpAccessToken     String?
  mpUserId          String?       @unique
  mpOnboarded       Boolean       @default(false)
  commissionRate    Float         @default(0.18)

  status            ArtisanStatus @default(PENDING)
  appliedAt         DateTime      @default(now())
  approvedAt        DateTime?
  rejectedReason    String?

  rating            Float         @default(0)
  reviewCount       Int           @default(0)
  totalSales        Int           @default(0)

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user              User          @relation(fields: [userId], references: [id])
  products          Product[]
  orderItems        OrderItem[]
  reviews           Review[]
  questions         ProductQuestion[]

  @@map("artisans")
}

enum ArtisanStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

// ─── PRODUCTOS ───

model Product {
  id              String          @id @default(cuid())
  artisanId       String
  slug            String          @unique
  name            String
  description     String          @db.Text
  story           String?         @db.Text
  price           Int
  compareAtPrice  Int?
  category        ProductCategory
  materials       String[]
  technique       String?
  dimensions      String?
  weight          Float?

  isUnique        Boolean         @default(true)
  editionSize     Int?
  stock           Int             @default(1)

  isCustomMade    Boolean         @default(false)
  isReturnable    Boolean         @default(true)

  images          ProductImage[]

  status          ProductStatus   @default(DRAFT)
  adminNotes      String?
  publishedAt     DateTime?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  artisan         Artisan         @relation(fields: [artisanId], references: [id])
  orderItems      OrderItem[]
  reviews         Review[]
  questions       ProductQuestion[]
  favorites       Favorite[]
  cartItems       CartItem[]
  certificate     Certificate?

  @@index([artisanId])
  @@index([category])
  @@index([status])
  @@map("products")
}

enum ProductCategory {
  AROS
  COLLAR
  ANILLO
  PULSERA
  BROCHE
  COLGANTE
  OTRO
}

enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  PAUSED
  SOLD_OUT
}

model ProductImage {
  id          String            @id @default(cuid())
  productId   String
  url         String
  altText     String?
  position    Int               @default(0)
  status      ImageStatus       @default(PENDING_REVIEW)
  isOriginal  Boolean           @default(true)
  originalUrl String?
  createdAt   DateTime          @default(now())

  product     Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

enum ImageStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  REPLACED
}

// ─── CARRITO ───

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("cart_items")
}

// ─── PEDIDOS ───

model Order {
  id                  String       @id @default(cuid())
  orderNumber         String       @unique
  userId              String

  shippingName        String
  shippingAddress     String
  shippingCity        String
  shippingRegion      String
  shippingPostalCode  String?
  shippingCountry     String       @default("CL")

  subtotal            Int
  shippingCost        Int          @default(0)
  total               Int

  mpPaymentId         String?      @unique
  mpMerchantOrderId   String?

  status              OrderStatus  @default(PENDING_PAYMENT)

  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  user                User         @relation(fields: [userId], references: [id])
  items               OrderItem[]
  disputes            Dispute[]

  @@index([userId])
  @@map("orders")
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PARTIALLY_SHIPPED
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

model OrderItem {
  id              String          @id @default(cuid())
  orderId         String
  productId       String
  artisanId       String

  productName     String
  productPrice    Int
  quantity        Int             @default(1)

  commissionRate  Float
  commissionAmount Int
  artisanPayout   Int

  mpTransactionId  String?
  payoutStatus     PayoutStatus   @default(HELD)
  payoutAt         DateTime?

  fulfillmentStatus FulfillmentStatus @default(PENDING)
  trackingNumber    String?
  trackingCarrier   String?
  shippedAt         DateTime?
  deliveredAt       DateTime?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  order           Order           @relation(fields: [orderId], references: [id])
  product         Product         @relation(fields: [productId], references: [id])
  artisan         Artisan         @relation(fields: [artisanId], references: [id])

  @@index([orderId])
  @@index([artisanId])
  @@map("order_items")
}

enum FulfillmentStatus {
  PENDING
  PREPARING
  SHIPPED
  DELIVERED
  RETURNED
}

enum PayoutStatus {
  HELD
  RELEASED
  REFUNDED
  DISPUTED
}

// ─── PREGUNTAS PÚBLICAS ───

model ProductQuestion {
  id          String    @id @default(cuid())
  productId   String
  userId      String
  artisanId   String

  question    String    @db.Text
  answer      String?   @db.Text
  answeredAt  DateTime?

  isPublic    Boolean   @default(true)
  isBlocked   Boolean   @default(false)

  createdAt   DateTime  @default(now())

  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])
  artisan     Artisan   @relation(fields: [artisanId], references: [id])

  @@index([productId])
  @@map("product_questions")
}

// ─── REVIEWS ───

model Review {
  id          String   @id @default(cuid())
  productId   String
  artisanId   String
  userId      String
  orderId     String?

  rating      Int
  comment     String   @db.Text
  images      String[]

  response    String?  @db.Text
  respondedAt DateTime?

  isVerified  Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product     Product  @relation(fields: [productId], references: [id])
  artisan     Artisan  @relation(fields: [artisanId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
  @@index([productId])
  @@index([artisanId])
  @@map("reviews")
}

// ─── FAVORITOS ───

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("favorites")
}

// ─── CERTIFICADOS DE AUTENTICIDAD ───

model Certificate {
  id          String   @id @default(cuid())
  productId   String   @unique
  orderItemId String?

  code        String   @unique
  materials   String
  technique   String?
  artisanName String

  issuedAt    DateTime @default(now())

  product     Product  @relation(fields: [productId], references: [id])

  @@map("certificates")
}

// ─── DISPUTAS ───

model Dispute {
  id          String        @id @default(cuid())
  orderId     String
  userId      String

  reason      DisputeReason
  description String        @db.Text
  images      String[]

  status      DisputeStatus @default(OPEN)
  resolution  String?       @db.Text
  resolvedAt  DateTime?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order       Order         @relation(fields: [orderId], references: [id])
  user        User          @relation(fields: [userId], references: [id])

  @@map("disputes")
}

enum DisputeReason {
  NOT_AS_DESCRIBED
  NOT_RECEIVED
  DAMAGED
  WRONG_ITEM
  OTHER
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_REFUND
  RESOLVED_PARTIAL_REFUND
  RESOLVED_NO_REFUND
  CLOSED
}

// ─── DEVOLUCIONES ───

model ReturnRequest {
  id            String        @id @default(cuid())
  orderItemId   String
  userId        String

  reason        ReturnReason
  description   String?       @db.Text
  images        String[]

  shippingPaidBy ReturnShippingPayer @default(BUYER)

  returnTrackingNumber  String?
  returnTrackingCarrier String?

  status        ReturnStatus  @default(REQUESTED)
  adminNotes    String?
  resolvedAt    DateTime?
  refundAmount  Int?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("return_requests")
}

enum ReturnReason {
  NOT_AS_DESCRIBED
  DAMAGED_ON_ARRIVAL
  WRONG_ITEM
  BUYER_REGRET
  DEFECTIVE
  OTHER
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  SHIPPED_BACK
  RECEIVED_BY_ARTISAN
  REFUNDED
  CLOSED
}

enum ReturnShippingPayer {
  PLATFORM
  BUYER
}

// ─── POSTULACIONES ───

model ArtisanApplication {
  id              String    @id @default(cuid())
  email           String
  name            String
  location        String
  specialty       String
  bio             String    @db.Text
  portfolioImages String[]
  portfolioUrl    String?
  materials       String[]
  experience      String?   @db.Text
  phone           String?

  status          ArtisanApplicationStatus @default(PENDING)
  reviewedAt      DateTime?
  reviewNotes     String?

  createdAt       DateTime  @default(now())

  @@map("artisan_applications")
}

enum ArtisanApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── MEMBRESÍAS (v2) ───

model MembershipPlan {
  id              String    @id @default(cuid())
  name            String
  price           Int
  commissionRate  Float
  features        String[]
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  subscriptions   MembershipSubscription[]

  @@map("membership_plans")
}

model MembershipSubscription {
  id          String                   @id @default(cuid())
  artisanId   String
  planId      String
  status      MembershipStatus         @default(ACTIVE)
  startDate   DateTime                 @default(now())
  endDate     DateTime?
  cancelledAt DateTime?

  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  plan        MembershipPlan           @relation(fields: [planId], references: [id])

  @@map("membership_subscriptions")
}

enum MembershipStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}
