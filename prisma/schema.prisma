generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String            @id @default(cuid())
  name           String?
  email          String            @unique
  emailVerified  DateTime?
  hashedPassword String?
  image          String?
  role           UserRole          @default(BUYER)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  accounts       Account[]
  artisan        Artisan?
  cartItems      CartItem[]
  disputes       Dispute[]
  favorites      Favorite[]
  orders         Order[]
  questions      ProductQuestion[]
  referralCode   String?           @unique
  referredBy     String?
  referralRewardsEarned  ReferralReward[] @relation("ReferrerRewards")
  referralRewardsGiven   ReferralReward[] @relation("ReferredRewards")
  reviews        Review[]
  sessions       Session[]
  wishlists      Wishlist[]

  // Email verification
  verificationToken        String?
  verificationTokenExpires DateTime?

  // Password reset (credentials only)
  passwordResetToken        String?
  passwordResetExpires      DateTime?

  // Role switcher for admins
  activeRole String?

  // Saved shipping address
  shippingName       String?
  shippingAddress    String?
  shippingCity       String?
  shippingRegion     String?
  shippingPostalCode String?
  shippingPhone      String?

  // Chat relations
  buyerConversations Conversation[] @relation("BuyerConversations")
  sentMessages       Message[]

  // Gift cards
  giftCardsPurchased GiftCard[] @relation("GiftCardsPurchased")

  // Blog
  blogPosts BlogPost[]

  // Guided tours
  tourCompletions TourCompletion[]

  // Legal acceptances
  legalAcceptances LegalAcceptance[]

  // Return requests
  returnRequests ReturnRequest[] @relation("UserReturns")

  @@map("users")
}

model TourCompletion {
  id          String    @id @default(cuid())
  userId      String
  tourId      String
  completedAt DateTime  @default(now())
  skippedAt   DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tourId])
  @@map("tour_completions")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Artisan {
  id             String            @id @default(cuid())
  userId         String            @unique
  slug           String            @unique
  displayName    String
  bio            String
  story          String?
  region         String?
  location       String
  specialty      String
  specialties    Specialty[]
  materials      String[]
  profileImage   String?
  workshopImages String[]
  videoUrl         String?
  yearsExperience  Int?
  awards           String[]
  socialLinks      Json?
  rut            String?
  phone          String?
  mpAccessToken    String?
  mpRefreshToken   String?
  mpUserId         String?           @unique
  mpOnboarded      Boolean           @default(false)
  mpTokenExpiresAt DateTime?
  bankName            String?
  bankAccountType     String?
  bankAccountNumber   String?
  bankRut             String?
  bankHolderName      String?
  bankDataUpdatedAt   DateTime?
  commissionRate      Float                    @default(0.18)
  commissionOverride  Float?
  maxProductsOverride Int?
  maxPhotosOverride   Int?
  isPioneer           Boolean   @default(false)
  pioneerUntil        DateTime?
  pioneerGrantedBy    String?
  homeHighlight       Boolean                  @default(false)
  status              ArtisanStatus            @default(PENDING)
  appliedAt           DateTime                 @default(now())
  approvedAt          DateTime?
  rejectedReason      String?
  rating              Float                    @default(0)
  reviewCount         Int                      @default(0)
  totalSales          Int                      @default(0)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  user                User                     @relation(fields: [userId], references: [id])
  orderItems          OrderItem[]
  questions           ProductQuestion[]
  products            Product[]
  reviews             Review[]
  subscriptions       MembershipSubscription[]
  conversations       Conversation[]
  artisanMaterials     ArtisanMaterial[]
  collections          Collection[]

  @@map("artisans")
}

model MaterialPrice {
  id           String   @id @default(cuid())
  name         String   @unique
  pricePerGram Int
  unit         String   @default("gramo")
  updatedAt    DateTime @updatedAt
  updatedBy    String?

  @@map("material_prices")
}

model ArtisanMaterial {
  id           String   @id @default(cuid())
  artisanId    String
  artisan      Artisan  @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  name         String
  pricePerUnit Int
  unit         String   @default("gramo")
  isCustom     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([artisanId, name])
  @@map("artisan_materials")
}

model Collection {
  id          String    @id @default(cuid())
  artisanId   String
  name        String
  slug        String
  description String?
  isActive    Boolean   @default(true)
  position    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  artisan     Artisan   @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  products    Product[]

  @@unique([artisanId, slug])
  @@index([artisanId])
  @@map("collections")
}

model Product {
  id             String            @id @default(cuid())
  artisanId      String
  slug           String            @unique
  name           String
  description    String
  story          String?
  price          Int
  compareAtPrice Int?
  categories     Category[]
  materials      Material[]
  specialties    Specialty[]
  occasions      Occasion[]
  technique      String?
  dimensions     String?
  weight         Float?
  productionType  ProductionType    @default(UNIQUE)
  isCustomizable  Boolean           @default(false)
  elaborationDays Int?
  stock          Int               @default(1)
  collectionId   String?
  collection     Collection?   @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  tallas         String[]
  tallaUnica     String?
  tallaAjusteArriba Int?
  tallaAjusteAbajo  Int?
  guiaTallas     String?
  largoCadenaCm  Float?
  tieneCadena    Boolean?
  espesorCadenaMm Float?
  diametroMm     Float?
  audiencia      ProductAudience   @default(SIN_ESPECIFICAR)

  // ── Colgantes y dijes ──
  pendantWidth    Float?    // Ancho del colgante/dije en mm
  pendantHeight   Float?    // Alto del colgante/dije en mm

  // ── Aros ──
  earringWidth    Float?    // Ancho del aro en mm
  earringDrop     Float?    // Largo de caída desde lóbulo en mm

  // ── Broches ──
  broochWidth     Float?    // Ancho del broche en mm
  broochHeight    Float?    // Alto del broche en mm

  // ── Piercing ──
  piercingGauge     String?   // Calibre: "20G", "18G", "16G", "14G"
  piercingBarLength Float?    // Largo de barra en mm

  personalizable Boolean           @default(false)
  detallePersonalizacion String?
  tiempoElaboracionDias  Int?
  cantidadEdicion        Int?
  variants       ProductVariant[]
  stones         ProductStone[]
  cuidados       String?
  empaque        String?
  garantia       String?
  isReturnable   Boolean           @default(true)
  viewCount      Int               @default(0)
  status         ProductStatus     @default(DRAFT)
  pauseReason    ProductPauseReason?
  pausedAt       DateTime?
  isCuratorPick  Boolean           @default(false)
  curatorPickAt  DateTime?
  curatorNote    String?
  adminNotes     String?
  publishedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  cartItems      CartItem[]
  certificate    Certificate?
  favorites      Favorite[]
  orderItems     OrderItem[]
  images         ProductImage[]
  video          ProductVideo?
  questions      ProductQuestion[]
  artisan        Artisan           @relation(fields: [artisanId], references: [id])
  reviews        Review[]
  wishlistItems  WishlistItem[]
  conversations  Conversation[]

  @@index([artisanId])
  @@index([collectionId])
  @@index([status])
  @@map("products")
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  size      String
  stock     Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, size])
  @@index([productId])
  @@map("product_variants")
}

model ProductImage {
  id          String      @id @default(cuid())
  productId   String
  url         String
  altText     String?
  position    Int         @default(0)
  status          ImageStatus @default(PENDING_REVIEW)
  rejectionReason String?
  isOriginal      Boolean     @default(true)
  originalUrl     String?
  createdAt   DateTime    @default(now())
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductVideo {
  id                  String      @id @default(cuid())
  productId           String      @unique
  cloudflareStreamUid String
  status              VideoStatus @default(PROCESSING)
  muted               Boolean     @default(false)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  product             Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_videos")
}

model ProductStone {
  id           String   @id @default(cuid())
  productId    String
  stoneType    String   // Rubí, Esmeralda, Lapislázuli, etc.
  stoneCarat   Float?   // Peso en quilates (ct). 1 ct = 0.2 gramos
  stoneColor   String?  // Color: azul intenso, verde esmeralda, etc.
  stoneCut     String?  // Corte: cabujón, facetado, briolette, rosa, bruta
  stoneOrigin  String?  // Origen: natural, laboratorio, sintética
  stoneClarity String?  // Claridad: transparente, translúcida, opaca
  quantity     Int      @default(1)
  position     Int      @default(0) // 0 = piedra principal
  createdAt    DateTime @default(now())
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_stones")
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  size      String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, size])
  @@map("cart_items")
}

model Order {
  id                 String      @id @default(cuid())
  orderNumber        String      @unique
  userId             String
  shippingName       String
  shippingAddress    String
  shippingCity       String
  shippingRegion     String
  shippingPostalCode String?
  shippingCountry    String      @default("CL")
  subtotal           Int
  shippingCost       Int         @default(0)
  total              Int
  mpPaymentId        String?     @unique
  mpMerchantOrderId  String?
  mpFeeAmount        Int?
  mpNetReceived      Int?
  status             OrderStatus @default(PENDING_PAYMENT)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  discountCode       String?
  discountAmount     Int         @default(0)
  isGift             Boolean     @default(false)
  giftMessage        String?
  giftWrapping       Boolean     @default(false)
  giftWrappingPrice  Int         @default(0)
  giftCardDiscount   Int         @default(0)
  giftCardCode       String?
  disputes           Dispute[]
  items              OrderItem[]
  referralRewards    ReferralReward[]
  user               User        @relation(fields: [userId], references: [id])
  giftCard           GiftCard?   @relation("GiftCardOrder")
  giftCardUsages     GiftCardUsage[]

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id                String            @id @default(cuid())
  orderId           String
  productId         String
  artisanId         String
  productName       String
  productPrice      Int
  quantity          Int               @default(1)
  size              String?
  commissionRate    Float
  commissionAmount  Int
  artisanPayout     Int
  mpTransactionId   String?
  payoutStatus      PayoutStatus      @default(HELD)
  payoutAt          DateTime?
  fulfillmentStatus FulfillmentStatus @default(PENDING)
  trackingNumber    String?
  trackingCarrier   String?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  receivedAt        DateTime?         // Buyer confirmed receipt
  autoReceivedAt    DateTime?         // Auto-confirmed by cron (10 days post-ship)
  payoutEligibleAt  DateTime?         // When payout can be released (receivedAt + plan days)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  artisan           Artisan           @relation(fields: [artisanId], references: [id])
  order             Order             @relation(fields: [orderId], references: [id])
  product           Product           @relation(fields: [productId], references: [id])
  returnRequests    ReturnRequest[]

  @@index([orderId])
  @@index([artisanId])
  @@map("order_items")
}

model ProductQuestion {
  id         String    @id @default(cuid())
  productId  String
  userId     String
  artisanId  String
  question   String
  answer     String?
  answeredAt DateTime?
  isPublic   Boolean   @default(true)
  isBlocked  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  artisan    Artisan   @relation(fields: [artisanId], references: [id])
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id])

  @@index([productId])
  @@map("product_questions")
}

model Review {
  id          String    @id @default(cuid())
  productId   String
  artisanId   String
  userId      String
  orderId     String?
  rating      Int
  comment     String
  images      String[]
  response    String?
  respondedAt DateTime?
  isVerified  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  artisan     Artisan   @relation(fields: [artisanId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
  @@index([productId])
  @@index([artisanId])
  @@map("reviews")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("favorites")
}

model Certificate {
  id          String   @id @default(cuid())
  productId   String   @unique
  orderItemId String?
  code        String   @unique
  materials   String
  technique   String?
  artisanName String
  issuedAt    DateTime @default(now())
  product     Product  @relation(fields: [productId], references: [id])

  @@map("certificates")
}

model Dispute {
  id          String        @id @default(cuid())
  orderId     String
  userId      String
  reason      DisputeReason
  description String
  images      String[]
  status      DisputeStatus @default(OPEN)
  resolution  String?
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  order       Order         @relation(fields: [orderId], references: [id])
  user        User          @relation(fields: [userId], references: [id])

  @@map("disputes")
}

model ReturnRequest {
  id                    String              @id @default(cuid())
  orderItemId           String
  userId                String
  reason                ReturnReason
  description           String?
  images                String[]
  shippingPaidBy        ReturnShippingPayer @default(BUYER)
  returnTrackingNumber  String?
  returnTrackingCarrier String?
  status                ReturnStatus        @default(REQUESTED)
  adminNotes            String?
  resolvedAt            DateTime?
  refundAmount          Int?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  orderItem             OrderItem           @relation(fields: [orderItemId], references: [id])
  user                  User                @relation("UserReturns", fields: [userId], references: [id])

  @@map("return_requests")
}

model ArtisanApplication {
  id              String                   @id @default(cuid())
  email           String
  name            String
  region          String?
  location        String
  specialty       String
  bio             String
  /** Categorías de piezas (tags del formulario). */
  categories      String[]                 @default([])
  portfolioImages String[]
  portfolioUrl    String?
  materials       String[]
  experience        String?
  yearsExperience   Int?
  awards            String[]
  phone             String?
  selectedPlan    String?
  promoCode       String?
  status          ArtisanApplicationStatus @default(PENDING)
  reviewedAt      DateTime?
  reviewNotes     String?
  createdAt       DateTime                 @default(now())

  @@map("artisan_applications")
}

model MembershipPlan {
  id                  String                   @id @default(cuid())
  name                String                   @unique
  price               Int
  annualPrice         Int?
  commissionRate      Float
  features            String[]
  maxProducts         Int                      @default(10)
  maxPhotosPerProduct Int                      @default(3)
  videoEnabled        Boolean                  @default(false)
  badgeText           String?
  badgeType           String?
  searchWeight        Float                    @default(1.0)
  payoutFrequency     String                   @default("quincenal")
  socialPostsPerMonth Int                      @default(0)
  supportLevel        String                   @default("email")
  hasCertificate      Boolean                  @default(false)
  homeHighlight       Boolean                  @default(false)
  hasBasicStats       Boolean                  @default(false)
  hasAdvancedStats    Boolean                  @default(false)
  isActive            Boolean                  @default(true)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  subscriptions       MembershipSubscription[]

  @@map("membership_plans")
}

model MembershipSubscription {
  id                    String             @id @default(cuid())
  artisanId             String
  planId                String
  status                MembershipStatus   @default(ACTIVE)
  startDate             DateTime           @default(now())
  endDate               DateTime?
  cancelledAt           DateTime?
  source                SubscriptionSource @default(PAYMENT)
  promoCodeId           String?
  graceEndsAt           DateTime?
  gracePeriodNotified   Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  artisan               Artisan            @relation(fields: [artisanId], references: [id])
  plan                  MembershipPlan     @relation(fields: [planId], references: [id])

  @@map("membership_subscriptions")
}

model PromoCode {
  id           String              @id @default(cuid())
  code         String              @unique
  type         PromoCodeType       @default(FREE_TRIAL)
  planName     String
  durationDays Int                 @default(90)
  maxUses      Int                 @default(1)
  currentUses  Int                 @default(0)
  expiresAt    DateTime
  isActive     Boolean             @default(true)
  campaign     String
  metadata     Json?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  redemptions  PromoCodeRedemption[]

  // Invitation tracking
  recipientName    String?
  recipientEmail   String?
  invitationStatus InvitationStatus @default(DRAFT)
  sentAt           DateTime?
  openedAt         DateTime?
  appliedAt        DateTime?
  redeemedAt       DateTime?

  @@index([campaign])
  @@index([code])
  @@map("promo_codes")
}

model PromoCodeRedemption {
  id          String    @id @default(cuid())
  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id])
  artisanId   String?
  email       String
  redeemedAt  DateTime  @default(now())

  @@unique([promoCodeId, email])
  @@index([artisanId])
  @@map("promo_code_redemptions")
}

model Wishlist {
  id        String         @id @default(cuid())
  userId    String
  name      String
  code      String         @unique
  isPublic  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WishlistItem[]

  @@index([userId])
  @@map("wishlists")
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  productId  String
  addedAt    DateTime @default(now())
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, productId])
  @@map("wishlist_items")
}

enum UserRole {
  BUYER
  ARTISAN
  ADMIN
}

enum ArtisanStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  PAUSED
  SOLD_OUT
}

enum ImageStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  REPLACED
}

enum VideoStatus {
  PROCESSING
  READY
  ERROR
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PARTIALLY_SHIPPED
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum FulfillmentStatus {
  PENDING
  PREPARING
  SHIPPED
  DELIVERED
  RETURNED
}

enum PayoutStatus {
  HELD
  PENDING
  RELEASED
  PAID
  REFUNDED
  DISPUTED
}

enum DisputeReason {
  NOT_AS_DESCRIBED
  NOT_RECEIVED
  DAMAGED
  WRONG_ITEM
  OTHER
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_REFUND
  RESOLVED_PARTIAL_REFUND
  RESOLVED_NO_REFUND
  CLOSED
}

enum ReturnReason {
  NOT_AS_DESCRIBED
  DAMAGED_ON_ARRIVAL
  WRONG_ITEM
  BUYER_REGRET
  DEFECTIVE
  OTHER
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  SHIPPED_BACK
  RECEIVED_BY_ARTISAN
  REFUNDED
  CLOSED
}

enum ReturnShippingPayer {
  PLATFORM
  BUYER
}

enum ArtisanApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ---------------------------------------------------------------------------
// Blog
// ---------------------------------------------------------------------------

enum BlogCategory {
  GUIAS
  TENDENCIAS
  ORFEBRES
  CUIDADOS
  MATERIALES
  CULTURA
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model BlogPost {
  id             String       @id @default(cuid())
  slug           String       @unique
  title          String
  excerpt        String
  content        String
  coverImage     String?
  category       BlogCategory
  tags           String[]
  authorId       String
  author         User         @relation(fields: [authorId], references: [id])
  status         BlogStatus   @default(DRAFT)
  publishedAt    DateTime?
  seoTitle       String?
  seoDescription String?
  readingTime    Int?
  featured       Boolean      @default(false)
  viewCount      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("blog_posts")
}

enum RewardType {
  DISCOUNT
  CREDIT
}

enum RewardStatus {
  PENDING
  ACTIVATED
  USED
  EXPIRED
}

model ReferralReward {
  id           String       @id @default(cuid())
  referrerId   String
  referredId   String
  rewardType   RewardType   @default(DISCOUNT)
  rewardAmount Int          @default(5000)
  code         String       @unique
  status       RewardStatus @default(ACTIVATED)
  activatedAt  DateTime     @default(now())
  usedAt       DateTime?
  expiresAt    DateTime
  orderId      String?
  referrer     User         @relation("ReferrerRewards", fields: [referrerId], references: [id])
  referred     User         @relation("ReferredRewards", fields: [referredId], references: [id])
  order        Order?       @relation(fields: [orderId], references: [id])
  createdAt    DateTime     @default(now())

  @@index([referrerId])
  @@index([code])
  @@map("referral_rewards")
}

enum MembershipStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  GRACE_PERIOD
}

enum PromoCodeType {
  PLAN_UPGRADE
  FREE_TRIAL
  DISCOUNT
}

enum SubscriptionSource {
  PAYMENT
  PROMO_CODE
  DEFAULT
  ADMIN
}

enum ProductPauseReason {
  DOWNGRADE
  MANUAL
  ADMIN
  MODERATION
}

enum ProductionType {
  UNIQUE        // Pieza única — stock siempre 1, desaparece al venderse
  MADE_TO_ORDER // Hecha por encargo — se fabrica al comprar, sin stock, sin devolución
  LIMITED       // Producción limitada/múltiple — tiene stock (global o por talla)
}

enum ProductAudience {
  MUJER
  HOMBRE
  UNISEX
  NINOS
  SIN_ESPECIFICAR
}

enum InvitationStatus {
  DRAFT
  SENT
  OPENED
  APPLIED
  REDEEMED
  EXPIRED
}

// ---------------------------------------------------------------------------
// Gift Cards
// ---------------------------------------------------------------------------

enum GiftCardStatus {
  ACTIVE
  PARTIALLY_USED
  REDEEMED
  EXPIRED
  CANCELLED
}

model GiftCard {
  id             String         @id @default(cuid())
  code           String         @unique
  amount         Int
  balance        Int
  purchaserId    String
  purchaser      User           @relation("GiftCardsPurchased", fields: [purchaserId], references: [id])
  recipientEmail String
  recipientName  String?
  message        String?
  status         GiftCardStatus @default(ACTIVE)
  purchasedAt    DateTime       @default(now())
  redeemedAt     DateTime?
  expiresAt      DateTime
  orderId        String?        @unique
  order          Order?         @relation("GiftCardOrder", fields: [orderId], references: [id])
  usedInOrders   GiftCardUsage[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([purchaserId])
  @@index([recipientEmail])
  @@map("gift_cards")
}

model GiftCardUsage {
  id         String   @id @default(cuid())
  giftCardId String
  giftCard   GiftCard @relation(fields: [giftCardId], references: [id])
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  amount     Int
  createdAt  DateTime @default(now())

  @@index([giftCardId])
  @@index([orderId])
  @@map("gift_card_usages")
}

// ---------------------------------------------------------------------------
// Chat / Messaging
// ---------------------------------------------------------------------------

model Conversation {
  id               String             @id @default(cuid())
  buyerId          String
  buyer            User               @relation("BuyerConversations", fields: [buyerId], references: [id])
  artisanId        String
  artisan          Artisan            @relation(fields: [artisanId], references: [id])
  productId        String?
  product          Product?           @relation(fields: [productId], references: [id])
  status           ConversationStatus @default(ACTIVE)
  hasBypassAttempt Boolean            @default(false)
  lastMessageAt    DateTime           @default(now())
  lastNotifiedBuyerAt  DateTime?
  lastNotifiedArtisanAt DateTime?
  messages         Message[]
  deletedAt        DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@unique([buyerId, artisanId])
  @@index([artisanId])
  @@map("conversations")
}

model Message {
  id             String             @id @default(cuid())
  conversationId String
  conversation   Conversation       @relation(fields: [conversationId], references: [id])
  senderId       String
  sender         User               @relation(fields: [senderId], references: [id])
  senderRole     MessageSenderRole
  content        String
  isRead         Boolean            @default(false)
  isBlocked      Boolean            @default(false)
  blockedReason  String?
  visibleTo      MessageSenderRole? // null = visible to all, BUYER/ARTISAN = only that role sees it
  deletedAt      DateTime?          // soft delete for admin
  createdAt      DateTime           @default(now())

  @@index([conversationId])
  @@map("messages")
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
  BLOCKED
}

enum MessageSenderRole {
  BUYER
  ARTISAN
  ADMIN
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  position  Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@map("categories")
}

model Material {
  id        String    @id @default(cuid())
  name      String    @unique
  position  Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@map("materials")
}

model Occasion {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  position  Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@map("occasions")
}

model Specialty {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  position  Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
  artisans  Artisan[]

  @@map("specialties")
}

model ShippingZone {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  regions       String[]
  price         Int
  estimatedDays String
  isActive      Boolean  @default(true)
  position      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("shipping_zones")
}

model ShippingSettings {
  id                    String   @id @default("default")
  freeShippingEnabled   Boolean  @default(true)
  freeShippingThreshold Int      @default(100000)
  updatedAt             DateTime @updatedAt

  @@map("shipping_settings")
}

model AdminAsset {
  id         String   @id @default(cuid())
  key        String   @unique
  name       String
  fileName   String
  fileUrl    String
  fileSize   Int
  mimeType   String
  uploadedBy String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("admin_assets")
}

model LegalAcceptance {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentType    LegalDocumentType
  documentVersion String
  acceptedAt      DateTime          @default(now())
  ipAddress       String?
  userAgent       String?
  method          AcceptanceMethod  @default(CHECKBOX)

  @@index([userId])
  @@index([documentType, documentVersion])
  @@map("legal_acceptances")
}

enum LegalDocumentType {
  SELLER_AGREEMENT
  TERMS_AND_CONDITIONS
  PRIVACY_POLICY
}

enum AcceptanceMethod {
  CHECKBOX
  CLICK_WRAP
  BROWSE_WRAP
}
